# Application
PORT=3000
JWT_SECRET=change-me-to-a-secure-random-string

# Base de données (utilisé par l'app en dev local)
DATABASE_URL=postgresql://taskboard:taskboard@localhost:5432/taskboard

# PostgreSQL (utilisé par compose.yml pour créer le conteneur db)
POSTGRES_USER=taskboard
POSTGRES_PASSWORD=taskboard
POSTGRES_DB=taskboard

# SSH server (utilisé par compose.yml pour autoriser la clé de déploiement)
DEPLOY_PUBLIC_KEY=your-ed25519-public-key-here
